<cell xid="193" props="right-color:#000000; bot-style:solid; bot-thickness:0.05pt; right-attach:2; left-thickness:0.05pt; right-thickness:0.05pt; left-color:#000000; top-style:none; left-attach:1; left-style:solid; right-style:solid; bot-color:#000000; bot-attach:8; top-attach:7">
